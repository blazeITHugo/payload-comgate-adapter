{
  "name": "payload-comgate-adapter",
  "version": "0.3.0",
  "description": "Comgate payment gateway adapter for PayloadCMS ecommerce plugin",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./refund": {
      "types": "./dist/refund.d.ts",
      "import": "./dist/refund.js",
      "require": "./dist/refund.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "ecommerce",
    "payment",
    "comgate"
  ],
  "author": "blaze IT s.r.o. <info@blazeit.sk>",
  "license": "MIT",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blazeITHugo/payload-comgate-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/blazeITHugo/payload-comgate-adapter/issues"
  },
  "homepage": "https://github.com/blazeITHugo/payload-comgate-adapter#readme",
  "peerDependencies": {
    "@payloadcms/plugin-ecommerce": "^3.60.0",
    "payload": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "3.2.3"
  }
}
